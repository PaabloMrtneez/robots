{
  "name": "swiftlend",
  "version": "1.0.0",
  "description": "SwiftLend microservice for spec-driven microloan approvals.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "check:spec": "node scripts/checkSpecCompliance.js && npm test",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "swiftlend",
    "microservice",
    "typescript",
    "zod",
    "jest"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
